          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Calculate Prompt Length">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
              def prompt = vars.get(&quot;PROMPT&quot;)
              if (prompt != null) {
                  vars.put(&quot;PROMPT_LENGTH&quot;, prompt.length().toString())
              }
            </stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">false</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <JSR223Listener guiclass="TestBeanGUI" testclass="JSR223Listener" testname="Log Prompt Length vs Response Time">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
              def length = vars.get(&quot;PROMPT_LENGTH&quot;)
              def time = prev.getTime()
              log.info(&quot;Prompt length: ${length}, Response time: ${time} ms&quot;)
            </stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">false</stringProp>
          </JSR223Listener>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor ">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">// Calculate prompt length
def prompt = vars.get(&quot;PROMPT&quot;)
if (prompt != null) {
    vars.put(&quot;PROMPT_LENGTH&quot;, prompt.length().toString())
    vars.put(&quot;PROMPT&quot;, prompt)
}

// Capture response time (ms)
def time = prev.getTime()
vars.put(&quot;RESPONSE_TIME&quot;, time.toString())

// If you want the full reply text (with stream:false)
//def reply = prev.getResponseDataAsString()
//vars.put(&quot;OLLAMA_RESPONSE&quot;, reply)
</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="TestPlan.comments">for Prompt Length Vs Response time</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor Props object">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">def prompt = vars.get(&quot;PROMPT&quot;)
def length = vars.get(&quot;PROMPT_LENGTH&quot;)
def time = vars.get(&quot;RESPONSE_TIME&quot;)

// Retrieve existing list from props
def results = props.get(&quot;ollamaResults&quot;)
if (results == null) {
    results = []
}
results &lt;&lt; [length, prompt, time]

// Save back into props
props.put(&quot;ollamaResults&quot;, results)
</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="TestPlan.comments">Props Object</stringProp>
          </JSR223PostProcessor>
