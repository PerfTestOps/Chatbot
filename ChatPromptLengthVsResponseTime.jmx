      <JSR223Listener guiclass="TestBeanGUI" testclass="JSR223Listener" testname="JSR223 Listener" enabled="false">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonBuilder

// Collect stats in memory during the test
def prompt = vars.get(&quot;PROMPT&quot;)
def length = vars.get(&quot;PROMPT_LENGTH&quot;)
def time = vars.get(&quot;RESPONSE_TIME&quot;) as int

// Store in JMeter properties (shared across threads)
def stats = props.get(&quot;promptStats&quot;)
if (stats == null) {
    stats = [:]
} else {
    stats = new JsonSlurper().parseText(stats)
}

stats[prompt] = (stats[prompt] ?: []) + time
props.put(&quot;promptStats&quot;, new JsonBuilder(stats).toString())

// At the very end of the test, overwrite the file
if (ctx.isLastSample()) {
    def finalStats = new JsonSlurper().parseText(props.get(&quot;promptStats&quot;))
    def file = new File(&quot;ollama_promptlength_Vs_ResponseTime.csv&quot;)
    file.write(&quot;PromptLength,Prompt,AverageResponseTimeMs\n&quot;)
    finalStats.each { p, times -&gt;
        def avg = times.sum() / times.size()
        file &lt;&lt; &quot;${p.length()},\&quot;${p}\&quot;,${avg}\n&quot;
    }
}
</stringProp>
      </JSR223Listener>
