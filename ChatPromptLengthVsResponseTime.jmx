  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Ollama Prompt Length vs Response Time">
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments">
        <collectionProp name="Arguments.arguments">
          <elementProp name="PROMPTXXXX" elementType="Argument">
            <stringProp name="Argument.name">PROMPTXXXX</stringProp>
            <stringProp name="Argument.value">Hello Ollama, test prompt!</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
    </TestPlan>
